# ── PitchForge Backend — Environment Variables ───────
# Copy this to .env and fill in your values.

# App
APP_NAME=PitchForge
DEBUG=false
SECRET_KEY=change-me-to-a-random-string
ALLOWED_ORIGINS=https://pitch-forge.com,https://*.pages.dev,http://localhost:8000
LOG_LEVEL=INFO

# AI
DEEPSEEK_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...

# Auth (Clerk)
CLERK_SECRET_KEY=sk_...
CLERK_PUBLISHABLE_KEY=pk_...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=pitchforge

# Redis
REDIS_URL=redis://redis:6379

# Email (Resend)
RESEND_API_KEY=re_...

# Monitoring (Sentry)
SENTRY_DSN=https://...

# ListMonk (Waitlist)
LISTMONK_URL=https://newsletter.yourdomain.com
LISTMONK_USER=admin
LISTMONK_PASS=your-password
LISTMONK_LIST_ID=1
